datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  purchases Purchase[]
  progress  UserProgress[]
}

model Webinar {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  category        String
  categoryLabel   String?
  date            String
  duration        String?
  speaker         String
  speakerTitle    String?
  description     String
  posterFile      String?
  registrationUrl String?
  meetLink        String?
  tags            String[]
  createdAt       DateTime @default(now())
}

model Workshop {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  category        String
  categoryLabel   String?
  date            String?
  duration        String?
  instructor      String
  instructorTitle String?
  price           String?
  level           String?
  description     String
  posterFile      String?
  meetLink        String?
  tags            String[]
  curriculum      WorkshopModule[]
  createdAt       DateTime @default(now())
}

model WorkshopModule {
  id          String   @id @default(cuid())
  workshopId  String
  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  title       String
  description String
  duration    String
  meetLink    String?
  order       Int
  createdAt   DateTime @default(now())
}

model Mindshare {
  id          String   @id @default(cuid())
  title       String
  category    String
  date        String
  author      String
  content     String
  image       String?
  excerpt     String?
  meetLink    String?
  tags        String[]
  createdAt   DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       String
  description String
  image       String?
  category    String?
  tags        String[]
  createdAt   DateTime @default(now())
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productType   String   // 'workshop', 'webinar', 'mindshare', 'vip', 'product'
  productId     String
  amount        String
  status        String   @default("pending") // 'pending', 'paid', 'rejected'
  receiptFile   String?
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId   String
  completed  Boolean  @default(false)
  completedAt DateTime?
  createdAt  DateTime @default(now())
}

model VipOffer {
  id        String   @id @default(cuid())
  label     String
  price     String
  period    String   @default("/ mois")
  highlight Boolean  @default(false)
  features  String[] 
  order     Int      @default(0)
  sessions  VipSession[]
  createdAt DateTime @default(now())
}

model VipSession {
  id        String   @id @default(cuid())
  vipId     String
  vipOffer  VipOffer @relation(fields: [vipId], references: [id], onDelete: Cascade)
  title     String
  date      String?
  meetLink  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
